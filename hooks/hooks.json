{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/hook/inject-command-paths.sh\""
          }
        ],
        "description": "Inject PLUGIN_ROOT and PROJECT_ROOT when a bridgic command is loaded"
      }
    ]
  }
}
